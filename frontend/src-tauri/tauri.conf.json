{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "eBon Reader",
  "version": "0.1.0",
  "identifier": "com.ebon.reader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "eBon Reader",
        "width": 1600,
        "height": 1200,
        "resizable": true,
				"maximized": true
      }
    ]
  },
	"bundle": {
		"active": true,
		"targets": "nsis",
		"externalBin": ["binaries/ebon_backend"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
